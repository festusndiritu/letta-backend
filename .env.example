# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://letta:letta@db/letta

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Tiara Connect (SMS OTP) ────────────────────────────────────────────────
TIARA_API_KEY=your-key

# ─── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── DigitalOcean Spaces ───────────────────────────────────────────────────────
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=letta-media
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ─── FCM v1 ────────────────────────────────────────────────────────────────────
# FCM_SERVICE_ACCOUNT_JSON: open the downloaded JSON file, copy the entire
# contents, and paste it as the value of this variable (all on one line,
# or as a multiline value — both work)
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FCM_PROJECT_ID=your-firebase-project-id

# ─── Production ────────────────────────────
# DOMAIN=api.project.yourdomain.com
# ACME_EMAIL=youremail.com

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# Protects the GET /dashboard endpoint — set to any strong random string
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-me

# ─── Message encryption ────────────────────────────────────────────────────────
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MESSAGE_ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ─── Message retention ─────────────────────────────────────────────────────────
DELIVERED_MESSAGE_TTL_DAYS=7
UNDELIVERED_MESSAGE_TTL_DAYS=30
